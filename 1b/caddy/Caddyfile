# caddy/Caddyfile

# Caddy는 80번 포트에서 요청을 받습니다.
# (docker-compose.yml에서 호스트의 8080 포트와 연결됨)
:80 {
    # 1. /rpc 경로로 들어오는 모든 요청은 Geth 노드로 전달
    handle_path /rpc* {
        reverse_proxy geth:8545
    }

    # 2. /graphql 경로로 들어오는 모든 요청은 The Graph 노드의 GraphQL API로 전달
    handle_path /graphql* {
        reverse_proxy graph-node:8001
    }

    # 3. /subgraphs 경로로 들어오는 모든 요청은 The Graph 노드의 JSON-RPC API로 전달
    handle_path /subgraphs* {
        reverse_proxy graph-node:8000
    }

    # 4. 위 경로에 해당하지 않는 모든 요청에 대한 기본 응답
    handle {
        respond "dApp Backend Gateway is running!" 200
    }
}